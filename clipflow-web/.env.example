# Copy to .env.local and adjust (Next.js loads .env.local automatically).
# https://nextjs.org/docs/app/building-your-application/configuring/environment-variables

# ClipFlow / fadeflow API — no trailing slash. Used for browser fetch() to /signup, /login, etc.
# Production: https://fadeflow.onrender.com
# Local API: http://localhost:4242
NEXT_PUBLIC_API_BASE=https://fadeflow.onrender.com

# Optional: canonical site URL for metadata or absolute links
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe Checkout return URLs are configured on the API (Render env):
# CHECKOUT_SUCCESS_URL=https://your-domain/success
# CHECKOUT_CANCEL_URL=https://your-domain/cancel
# STRIPE_PRICE_ID=price_xxx   # API (Render) — one-time Price for ClipFlow Pro checkout
