# Stripe secret key (Dashboard → Developers → API keys → Secret key)
# Use sk_test_... for local development; never commit real keys.
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# One-time Price ID for POST /create-checkout-session (ClipFlow Pro)
# Example (test, $99 USD one-time): price_1TLG5wHwiNKuPTA8DHVlx1zS
STRIPE_PRICE_ID=price_your_one_time_price_here

# Hosted Checkout return URLs (same host as your Next site so localStorage token exists).
# Base success URL; server sets success_url to `${CHECKOUT_SUCCESS_URL}?session_id={CHECKOUT_SESSION_ID}` (uses & if URL already has ?).
CHECKOUT_SUCCESS_URL=https://your-site.com/success
CHECKOUT_CANCEL_URL=https://your-site.com/cancel

# Webhook signing secret (Developers → Webhooks → your endpoint → Signing secret). Required for POST /stripe-webhook.
STRIPE_WEBHOOK_SECRET=whsec_your_signing_secret_here

# Server port
PORT=4242
